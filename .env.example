# Local dev environment. Copy to .env. NEVER commit real secrets — in the
# cluster these come from the Helm ConfigMap (non-secret) and Sealed Secrets.
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_ALLOWED_HOSTS=*

POSTGRES_DB=payment
POSTGRES_USER=payment
POSTGRES_PASSWORD=payment
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8080/apis/registry/v2
LOG_LEVEL=INFO
